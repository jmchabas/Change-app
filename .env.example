# Telegram bot token — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Your Telegram user ID — restricts the bot to your account only.
# Send /myid to @userinfobot on Telegram to get it.
TELEGRAM_USER_ID=

# Anthropic API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Timezone (must be a valid IANA timezone string)
TZ=Pacific/Honolulu

# Port for the web dashboard (default 3000)
PORT=3000

# Database path — override for Railway persistent volume
# On Railway: set DATABASE_PATH=/data/lifeos.db and mount a volume at /data
# DATABASE_PATH=/data/lifeos.db

# Public base URL used by Fitbit OAuth callback on deploy
# Example: https://your-service.up.railway.app
APP_BASE_URL=

# Optional: override signed check-in link secret.
# If empty, app falls back to TELEGRAM_BOT_TOKEN for signing.
CHECKIN_LINK_SECRET=

# Dashboard authentication key — protects the web dashboard + API.
# Set any passphrase. Leave empty for local dev (no auth).
DASHBOARD_API_KEY=

# Fitbit integration (optional)
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
